# Copy this file to terraform.tfvars and fill in your actual values
# DO NOT commit terraform.tfvars to version control
# Sensitive values can be set via environment variables (TF_VAR_<name>) or tools like Vault

proxmox_api_url          = "https://proxmox.lab.home/api2/json"
proxmox_api_token        = "terraform@pve!provider=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_tls_insecure     = false  # Set to true for self-signed certificates
proxmox_nodes = {
  prometheus = "pve1",
  grafana    = "pve1",
}
proxmox_host_default_pwd = "changeme"
template_file_id         = "pve-cluster:vztmpl/debian13-docker-template.tar.gz"
static_ips = {
  prometheus = "192.168.1.50",
  grafana    = "192.168.1.51",
}
ai_stack_ips = {
  open_webui = "192.168.1.40",
  searxng    = "192.168.1.30",
  n8n        = "192.168.1.20",
}
