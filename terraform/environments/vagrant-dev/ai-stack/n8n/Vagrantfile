# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.define "n8n" do |n8n|
    # debian/testing64 is the closest to Debian 13 (Trixie) available
    # Alternative: use a custom-built trixie box from https://github.com/rgl/debian-vagrant
    n8n.vm.box = "cloud-image/debian-13"
    n8n.vm.hostname = "n8n"

    # Disable synced folder
    n8n.vm.synced_folder ".", "/vagrant", disabled: true

    # Private network for inter-VM communication
    n8n.vm.network "private_network", ip: "192.168.56.5"

    # Port forwarding for n8n (host:5678 -> guest:5678)
    n8n.vm.network "forwarded_port", guest: 5678, host: 5678
    
    # Resize disk to 50GB (requires vagrant-disksize plugin or manual resize)
    # Install plugin: vagrant plugin install vagrant-disksize
    n8n.vm.disk :disk, size: "50GB", primary: true

    n8n.vm.provider "virtualbox" do |vb|
      vb.name = "n8n"
      vb.memory = 6144
      vb.cpus = 2
    end

    # Provision Docker
    n8n.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y docker.io docker-compose
      systemctl enable docker
      systemctl start docker
      usermod -aG docker vagrant
    SHELL
  end
end
