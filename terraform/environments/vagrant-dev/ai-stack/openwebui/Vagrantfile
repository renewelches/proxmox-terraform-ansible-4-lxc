# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.define "openwebui" do |openwebui|
    # debian/testing64 is the closest to Debian 13 (Trixie) available
    # Alternative: use a custom-built trixie box from https://github.com/rgl/debian-vagrant
    openwebui.vm.box = "cloud-image/debian-13"
    openwebui.vm.hostname = "open-webui"

    # Disable synced folder
    openwebui.vm.synced_folder ".", "/vagrant", disabled: true

    # Private network for inter-VM communication
    openwebui.vm.network "private_network", ip: "192.168.56.3"

    # Port forwarding for Open WebUI (host:8080 -> guest:80)
    openwebui.vm.network "forwarded_port", guest: 80, host: 8080

    # Resize disk to 50GB (requires vagrant-disksize plugin or manual resize)
    # Install plugin: vagrant plugin install vagrant-disksize
    openwebui.vm.disk :disk, size: "50GB", primary: true

    openwebui.vm.provider "virtualbox" do |vb|
      vb.name = "openwebui"
      vb.memory = 1536
      vb.cpus = 2
    end

    # Provision Docker
    openwebui.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y docker.io docker-compose
      systemctl enable docker
      systemctl start docker
      usermod -aG docker vagrant
    SHELL
  end
end
