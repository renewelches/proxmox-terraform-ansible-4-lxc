# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.define "searxng" do |searxng|
    # debian/testing64 is the closest to Debian 13 (Trixie) available
    # Alternative: use a custom-built trixie box from https://github.com/rgl/debian-vagrant
    searxng.vm.box = "cloud-image/debian-13"
    searxng.vm.hostname = "searxng"

    # Disable synced folder
    searxng.vm.synced_folder ".", "/vagrant", disabled: true

    # Private network for inter-VM communication
    searxng.vm.network "private_network", ip: "192.168.56.4"

    # Port forwarding for SearXNG (host:8081 -> guest:80)
    searxng.vm.network "forwarded_port", guest: 80, host: 8081

    # Resize disk to 50GB (requires vagrant-disksize plugin or manual resize)
    # Install plugin: vagrant plugin install vagrant-disksize
    searxng.vm.disk :disk, size: "50GB", primary: true

    searxng.vm.provider "virtualbox" do |vb|
      vb.name = "searxng"
      vb.memory = 1024
      vb.cpus = 1
    end

    # Provision Docker
    searxng.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y docker.io docker-compose
      systemctl enable docker
      systemctl start docker
      usermod -aG docker vagrant
    SHELL
  end
end
