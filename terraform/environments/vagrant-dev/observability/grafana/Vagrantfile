# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.define "grafana" do |grafana|
    # debian/testing64 is the closest to Debian 13 (Trixie) available
    # Alternative: use a custom-built trixie box from https://github.com/rgl/debian-vagrant
    grafana.vm.box = "cloud-image/debian-13"
    grafana.vm.hostname = "grafana"

    # Disable synced folder
    grafana.vm.synced_folder ".", "/vagrant", disabled: true

    # Private network for inter-VM communication
    grafana.vm.network "private_network", ip: "192.168.56.5"

    # Port forwarding for n8n (host:5678 -> guest:5678)
    grafana.vm.network "forwarded_port", guest: 3000, host: 3000
    
    # Resize disk to 50GB (requires vagrant-disksize plugin or manual resize)
    # Install plugin: vagrant plugin install vagrant-disksize
    grafana.vm.disk :disk, size: "20GB", primary: true

    grafana.vm.provider "virtualbox" do |vb|
      vb.name = "grafana"
      vb.memory = 1024
      vb.cpus = 1
    end

    # Provision Docker
    grafana.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y docker.io docker-compose
      systemctl enable docker
      systemctl start docker
      usermod -aG docker vagrant
    SHELL
  end
end
