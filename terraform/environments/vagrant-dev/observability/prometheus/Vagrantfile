# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.define "prometheus" do |prometheus|
    # debian/testing64 is the closest to Debian 13 (Trixie) available
    # Alternative: use a custom-built trixie box from https://github.com/rgl/debian-vagrant
    prometheus.vm.box = "cloud-image/debian-13"
    prometheus.vm.hostname = "prometheus"

    # Disable synced folder
    prometheus.vm.synced_folder ".", "/vagrant", disabled: true

    # Private network for inter-VM communication
    prometheus.vm.network "private_network", ip: "192.168.56.6"

    # Port forwarding for prometheus (host:5678 -> guest:5678)
    prometheus.vm.network "forwarded_port", guest: 9090, host: 9090
    
    # Resize disk to 50GB (requires vagrant-disksize plugin or manual resize)
    # Install plugin: vagrant plugin install vagrant-disksize
    prometheus.vm.disk :disk, size: "20GB", primary: true

    prometheus.vm.provider "virtualbox" do |vb|
      vb.name = "prometheus"
      vb.memory = 2048
      vb.cpus = 1
    end

    # Provision Docker
    prometheus.vm.provision "shell", inline: <<-SHELL
      apt-get update
      apt-get install -y docker.io docker-compose
      systemctl enable docker
      systemctl start docker
      usermod -aG docker vagrant
    SHELL
  end
end
